# Django core
SECRET_KEY=change-me-generate-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# Origins must include scheme and port when a non-default port is used.
# Add your real domain here, for example: https://dbstat.example.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
TIME_ZONE=Europe/Minsk

# Key used to encrypt saved external DB connection passwords.
# Keep this stable: changing it makes existing encrypted passwords unreadable.
DB_CONNECTION_ENCRYPTION_KEY=change-me-generate-a-separate-long-random-secret

# Application database: sqlite or postgresql
DB_ENGINE=sqlite
SQLITE_NAME=db.sqlite3

# Use these only when DB_ENGINE=postgresql
DB_NAME=db_statistics
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Static files
STATIC_URL=static/
